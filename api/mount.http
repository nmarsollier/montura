@baseUrl = http://{{host}}/api
@alpacaBase = http://{{host}}/api/v1/telescope/0
@managementBase = http://{{host}}/management/v1

# ═══════════════════════════════════════════════════════════════
# Montura HTTP API Reference
#
# Both APIs share a single HTTP server on port 80.
# Set `host` in your .env or override here.
# ═══════════════════════════════════════════════════════════════

### ─── Variables ────────────────────────────────────────────────
@host = localhost
@cid = 1
@txid = {{$randomInt}}

# ═══════════════════════════════════════════════════════════════
# REST API — Custom endpoints
# ═══════════════════════════════════════════════════════════════

### Root / Screen (embedded SPA)
GET http://{{host}}/

### Status
GET {{baseUrl}}/status

# Response example
# {
#   "status": "ready",
#   "tracking": "sidereal",
#   "ra": "12:20:42.00",
#   "dec": "-32:07:12.00",
#   "settings": {
#     "lat": -32.890800,
#     "lon": -68.827200,
#     "elevation": 750
#   }
# }

### Tracking — set tracking mode
POST {{baseUrl}}/tracking
Content-Type: application/json

{
  "tracking": "sidereal"
}
# Valid values: none | manual | sidereal | lunar | solar

### Goto — slew to equatorial coordinates
POST {{baseUrl}}/goto
Content-Type: application/json

{
  "ra": 10.234,
  "dec": -20.123,
  "speed": 2
}
# ra: hours (0–24), dec: degrees (-90–90), speed: 0–3

### Move Axis — relative single-axis move
POST {{baseUrl}}/move-axis
Content-Type: application/json

{
  "axis": "ra",
  "degrees": 15.0,
  "speed": 2
}
# axis: ra | dec, degrees: relative delta, speed: 0–3

### Stop — halt all motion
POST {{baseUrl}}/stop

### Park — park the mount
POST {{baseUrl}}/park

### Unpark — take mount out of parked state
POST {{baseUrl}}/unpark

### Sync — align pointing model to known coordinates
POST {{baseUrl}}/sync
Content-Type: application/json

{
  "ra": 10.234,
  "dec": -20.123
}
# ra: hours (0–24), dec: degrees (-90–90)

### Home — slew to home position
POST {{baseUrl}}/home

### Settings — update site location and system time
POST {{baseUrl}}/settings
Content-Type: application/json

{
  "time": "2026-06-05T10:00:00-03:00",
  "lat": -32.8908,
  "lon": -68.8272,
  "elevation": 750
}

### Wi-Fi Config — set station credentials
POST {{baseUrl}}/wifi-config
Content-Type: application/json

{
  "ssid": "MyWiFi",
  "password": "secret123"
}

### ─── REST command responses ────────────────────────────────────
# All command endpoints return:
#   {"ok": true, "message": "..."}
# On rejection: HTTP 409 with {"ok": false, "message": "reason"}


# ═══════════════════════════════════════════════════════════════
# Alpaca Management API
# ═══════════════════════════════════════════════════════════════

### API versions
GET {{managementBase}}/apiversions

### Server description
GET {{managementBase}}/description

### Configured devices
GET {{managementBase}}/configureddevices


# ═══════════════════════════════════════════════════════════════
# Alpaca Telescope API — Common device endpoints
# ═══════════════════════════════════════════════════════════════

### Connected (GET)
GET {{alpacaBase}}/connected?ClientID={{cid}}&ClientTransactionID={{txid}}

### Connected (PUT)
PUT {{alpacaBase}}/connected?ClientID={{cid}}&ClientTransactionID={{txid}}
Content-Type: application/x-www-form-urlencoded

Connected=true

### Description
GET {{alpacaBase}}/description?ClientID={{cid}}&ClientTransactionID={{txid}}

### Driver info
GET {{alpacaBase}}/driverinfo?ClientID={{cid}}&ClientTransactionID={{txid}}

### Driver version
GET {{alpacaBase}}/driverversion?ClientID={{cid}}&ClientTransactionID={{txid}}

### Interface version
GET {{alpacaBase}}/interfaceversion?ClientID={{cid}}&ClientTransactionID={{txid}}

### Name
GET {{alpacaBase}}/name?ClientID={{cid}}&ClientTransactionID={{txid}}

### Supported actions
GET {{alpacaBase}}/supportedactions?ClientID={{cid}}&ClientTransactionID={{txid}}


